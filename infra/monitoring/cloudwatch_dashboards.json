{
  "DashboardName": "Rosier-Production",
  "DashboardBody": {
    "widgets": [
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ApplicationELB",
              "RequestCount",
              {
                "stat": "Sum"
              }
            ],
            [
              ".",
              "TargetResponseTime",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "ALB Request Volume & Response Time",
          "period": 60,
          "yAxis": {
            "left": {
              "min": 0
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ApplicationELB",
              "TargetResponseTime",
              {
                "stat": "p50"
              }
            ],
            [
              "...",
              {
                "stat": "p95"
              }
            ],
            [
              "...",
              {
                "stat": "p99"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "API Latency Percentiles",
          "period": 60,
          "yAxis": {
            "left": {
              "label": "Latency (s)"
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ApplicationELB",
              "HTTPCode_Target_4XX_Count",
              {
                "stat": "Sum"
              }
            ],
            [
              ".",
              "HTTPCode_Target_5XX_Count",
              {
                "stat": "Sum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": true,
          "region": "us-east-1",
          "title": "Error Rates (4XX, 5XX)",
          "period": 60,
          "yAxis": {
            "left": {
              "min": 0
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ECS",
              "CPUUtilization",
              "ServiceName",
              "rosier-api",
              "ClusterName",
              "rosier-production",
              {
                "stat": "Average"
              }
            ],
            [
              "...",
              {
                "stat": "Maximum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "ECS CPU Utilization",
          "period": 60,
          "yAxis": {
            "left": {
              "min": 0,
              "max": 100
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ECS",
              "MemoryUtilization",
              "ServiceName",
              "rosier-api",
              "ClusterName",
              "rosier-production",
              {
                "stat": "Average"
              }
            ],
            [
              "...",
              {
                "stat": "Maximum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "ECS Memory Utilization",
          "period": 60,
          "yAxis": {
            "left": {
              "min": 0,
              "max": 100
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/RDS",
              "DatabaseConnections",
              "DBInstanceIdentifier",
              "rosier-db",
              {
                "stat": "Average"
              }
            ],
            [
              "...",
              {
                "stat": "Maximum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "RDS Database Connections",
          "period": 60,
          "yAxis": {
            "left": {
              "min": 0
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/RDS",
              "ReadLatency",
              "DBInstanceIdentifier",
              "rosier-db",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "WriteLatency",
              "DBInstanceIdentifier",
              "rosier-db",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "RDS Query Latency",
          "period": 60,
          "yAxis": {
            "left": {
              "label": "Latency (ms)"
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/RDS",
              "FreeStorageSpace",
              "DBInstanceIdentifier",
              "rosier-db",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "RDS Free Storage",
          "period": 300,
          "yAxis": {
            "left": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ElastiCache",
              "BytesUsedForCache",
              "CacheClusterId",
              "rosier-redis",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "CacheBytes",
              "CacheClusterId",
              "rosier-redis",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "Redis Memory Usage",
          "period": 60,
          "yAxis": {
            "left": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ElastiCache",
              "CacheHits",
              "CacheClusterId",
              "rosier-redis",
              {
                "stat": "Sum"
              }
            ],
            [
              ".",
              "CacheMisses",
              "CacheClusterId",
              "rosier-redis",
              {
                "stat": "Sum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": true,
          "region": "us-east-1",
          "title": "Redis Hit/Miss Rate",
          "period": 60
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ElastiCache",
              "CurrentConnections",
              "CacheClusterId",
              "rosier-redis",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "Redis Connections",
          "period": 60
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ECS",
              "DesiredTaskCount",
              "ServiceName",
              "rosier-api",
              "ClusterName",
              "rosier-production",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "RunningCount",
              "ServiceName",
              "rosier-api",
              "ClusterName",
              "rosier-production",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "singleValue",
          "region": "us-east-1",
          "title": "ECS Task Count (Desired vs Running)"
        }
      },
      {
        "type": "log",
        "properties": {
          "query": "fields @timestamp, @message, @duration | filter @message like /ERROR/ | stats count() as error_count by bin(5m)",
          "region": "us-east-1",
          "title": "Error Rate (5-min bins)",
          "queryId": "error-rate"
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "Custom/Rosier",
              "CardQueueLength",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "CardQueueMaxLength",
              {
                "stat": "Maximum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "Card Queue Length",
          "period": 60
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "Custom/Rosier",
              "AffiliateClickThroughRate",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "Affiliate Link Click-Through Rate",
          "period": 300,
          "yAxis": {
            "left": {
              "min": 0,
              "max": 100,
              "label": "Percentage"
            }
          }
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "Custom/Rosier",
              "ActiveWebSocketConnections",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "PeakWebSocketConnections",
              {
                "stat": "Maximum"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": false,
          "region": "us-east-1",
          "title": "WebSocket Connections",
          "period": 60
        }
      },
      {
        "type": "metric",
        "properties": {
          "metrics": [
            [
              "AWS/ApplicationELB",
              "UnHealthyHostCount",
              {
                "stat": "Average"
              }
            ],
            [
              ".",
              "HealthyHostCount",
              {
                "stat": "Average"
              }
            ]
          ],
          "view": "timeSeries",
          "stacked": true,
          "region": "us-east-1",
          "title": "ALB Target Health",
          "period": 60
        }
      }
    ]
  }
}
