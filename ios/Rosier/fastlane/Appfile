# Fastlane App Store Connect Configuration

# Apple ID
apple_id(ENV['FASTLANE_USER'] || "developer@rosier.app")

# iTunes Connect Team ID
itc_team_id(ENV['ITC_TEAM_ID'] || "1234567890")
itc_team_name(ENV['ITC_TEAM_NAME'] || "Rosier Team")

# Developer Account Team ID
team_id(ENV['FASTLANE_TEAM_ID'] || "ABCDEF1234")
team_name(ENV['FASTLANE_TEAM_NAME'] || "Rosier Development Team")

# App Identifier(s)
app_identifier(
  default: "com.rosier.app",
  dev: "com.rosier.app.dev",
  internal: "com.rosier.app.internal"
)

# For all available options, check out Appfile documentation
