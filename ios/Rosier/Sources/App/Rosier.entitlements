<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<key>aps-environment</key>
	<string>development</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:rosier.app</string>
		<string>webcredentials:rosier.app</string>
	</array>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.rosier.app</string>
	</array>
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
	<key>com.apple.developer.networking.multicast</key>
	<true/>
	<key>com.apple.developer.networking.local-outbound-connection</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.rosier.app</string>
		<string>group.com.rosier.app.shared</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.rosier.app</string>
	</array>
</dict>
</plist>
