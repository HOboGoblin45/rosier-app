# ============================================================================
# ROSIER MARKETING AUTOMATION STACK - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env file with real credentials to git

# ============================================================================
# DATABASE CREDENTIALS
# ============================================================================
# PostgreSQL database password (used for all database users)
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Listmonk database
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=your-secure-listmonk-password-here
LISTMONK_DB_NAME=listmonk

# n8n database
N8N_DB_USER=n8n
N8N_DB_PASSWORD=your-secure-n8n-password-here
N8N_DB_NAME=n8n

# Mixpost database
MIXPOST_DB_USER=mixpost
MIXPOST_DB_PASSWORD=your-secure-mixpost-password-here
MIXPOST_DB_NAME=mixpost

# Plausible database
PLAUSIBLE_DB_PASSWORD=your-secure-plausible-password-here

# Redis cache
REDIS_PASSWORD=your-secure-redis-password-here


# ============================================================================
# SMTP CONFIGURATION (Email Sending)
# ============================================================================
# For Gmail: Use app-specific password (not your main Gmail password)
# Generate here: https://myaccount.google.com/apppasswords
#
# For SendGrid: Use "apikey" as username and your API key as password
#
# For Amazon SES: Use your AWS access key ID as username and secret key as password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password-here
MAIL_FROM=noreply@rosier.app
MAIL_REPLY_TO=hello@rosier.app
BOUNCE_ADMIN_EMAIL=admin@rosier.app


# ============================================================================
# LISTMONK CONFIGURATION
# ============================================================================
LISTMONK_ADMIN_USERNAME=admin
LISTMONK_ADMIN_PASSWORD=your-secure-listmonk-admin-password-here
# Generate a random token: openssl rand -hex 32
LISTMONK_AUTH_TOKEN=your-generated-auth-token-here


# ============================================================================
# n8n WORKFLOW AUTOMATION
# ============================================================================
# The host that n8n will be accessible at (for webhooks)
N8N_HOST=n8n.rosier.local
# Generate keys: openssl rand -base64 32
N8N_ENCRYPTION_KEY=your-generated-encryption-key-here
N8N_JWT_SECRET=your-generated-jwt-secret-here
# Webhook URLs (for triggering workflows from external services)
WEBHOOK_TUNNEL_URL=http://n8n.rosier.local:5678/
WEBHOOK_URL_PRODUCTION=http://n8n:5678/


# ============================================================================
# MIXPOST SOCIAL MEDIA SCHEDULING
# ============================================================================
# Generate key: base64 of openssl rand -base64 32
MIXPOST_APP_KEY=base64:your-generated-key-here
MIXPOST_DB_NAME=mixpost
MIXPOST_URL=http://localhost:9001


# ============================================================================
# PLAUSIBLE ANALYTICS
# ============================================================================
PLAUSIBLE_ADMIN_EMAIL=admin@rosier.app
PLAUSIBLE_ADMIN_PASSWORD=your-secure-plausible-password-here
# Generate key: openssl rand -base64 32
PLAUSIBLE_SECRET_KEY=your-generated-secret-key-here
PLAUSIBLE_BASE_URL=http://localhost:8100


# ============================================================================
# CORS & SECURITY
# ============================================================================
# Comma-separated list of allowed origins for API access
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:9000","http://localhost:5678","http://localhost:9001","http://localhost:8100"]


# ============================================================================
# OPTIONAL: Alternative Analytics (Uncomment if using Umami instead of Plausible)
# ============================================================================
# UMAMI_DB_PASSWORD=your-secure-umami-password-here
# UMAMI_HASH_SALT=your-generated-salt-here


# ============================================================================
# QUICK SETUP COMMANDS
# ============================================================================
# Generate secure random passwords and keys:
#
# POSTGRES_PASSWORD=$(openssl rand -base64 32)
# LISTMONK_DB_PASSWORD=$(openssl rand -base64 32)
# N8N_DB_PASSWORD=$(openssl rand -base64 32)
# MIXPOST_DB_PASSWORD=$(openssl rand -base64 32)
# PLAUSIBLE_DB_PASSWORD=$(openssl rand -base64 32)
# REDIS_PASSWORD=$(openssl rand -base64 32)
# LISTMONK_ADMIN_PASSWORD=$(openssl rand -base64 32)
# LISTMONK_AUTH_TOKEN=$(openssl rand -hex 32)
# N8N_ENCRYPTION_KEY=$(openssl rand -base64 32)
# N8N_JWT_SECRET=$(openssl rand -base64 32)
# MIXPOST_APP_KEY=base64:$(openssl rand -base64 32)
# PLAUSIBLE_ADMIN_PASSWORD=$(openssl rand -base64 32)
# PLAUSIBLE_SECRET_KEY=$(openssl rand -base64 32)
#
# Or use the setup.sh script to auto-generate all values
